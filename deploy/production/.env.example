# OmniSurg PRODUCTION deploy environment (template).
#
# Copy to deploy/production/.env (gitignored) and fill every value on the VPS at
# bootstrap. NAMES and SAFE PLACEHOLDERS ONLY live here; NEVER commit a real
# value (spec section 7). Placeholders are obvious non-values ("replace-with-...")
# so the go-common boot assertion rejects them in a non-local environment: any
# service that still holds a placeholder JWT secret or KEK fails closed at boot.
#
# deploy/render-env.sh reads this .env and writes the per-service, least-privilege
# env files under /opt/omnisurg/env. Each service receives ONLY the secrets it
# needs; no container holds another service's database password.
#
# OMNISURG_JWT_SECRET and OMNISURG_KEK_BASE64 MUST differ from local and from
# staging (parity gate, spec section 14): a staging-minted token must never
# validate in production, and PII encrypted in one environment must never decrypt
# in another. Generate fresh, strong values per environment.

# ---- Image tag ----
# The moving production tag (:prod) by default; the deploy job overrides this
# with the immutable commit :sha for a pinned rollout or rollback.
IMAGE_TAG=prod

# ---- Host-level deploy secret (NOT handed to any service container) ----
# Scoped read-only GitHub Container Registry token used once by `docker login
# ghcr.io` on the VPS to pull the private images. Never written to a service env.
GHCR_READ_TOKEN=replace-with-ghcr-read-only-token

# ---- Postgres ----
# The superuser (owns the cluster; creates the per-service roles at init). The
# 12 per-service role passwords below MUST each be DISTINCT and ALPHANUMERIC
# (no single quote): init.sh interpolates them into CREATE ROLE.
POSTGRES_USER=omnisurg
POSTGRES_PASSWORD=replace-with-strong-postgres-superuser-password
POSTGRES_DB=omnisurg_meta
OMNISURG_IDENTITY_DB_PASSWORD=replace-with-strong-identity-db-password
OMNISURG_TENANT_DB_PASSWORD=replace-with-strong-tenant-db-password
OMNISURG_PATIENT_DB_PASSWORD=replace-with-strong-patient-db-password
OMNISURG_CLINICAL_DB_PASSWORD=replace-with-strong-clinical-db-password
OMNISURG_REFERRAL_DB_PASSWORD=replace-with-strong-referral-db-password
OMNISURG_BILLING_DB_PASSWORD=replace-with-strong-billing-db-password
OMNISURG_PAYMENT_DB_PASSWORD=replace-with-strong-payment-db-password
OMNISURG_CLAIMS_DB_PASSWORD=replace-with-strong-claims-db-password
OMNISURG_NOTIFICATION_DB_PASSWORD=replace-with-strong-notification-db-password
OMNISURG_SCHEDULING_DB_PASSWORD=replace-with-strong-scheduling-db-password
OMNISURG_AUDIT_DB_PASSWORD=replace-with-strong-audit-db-password
OMNISURG_CURRENCY_DB_PASSWORD=replace-with-strong-currency-db-password

# ---- Redis ----
OMNISURG_REDIS_PASSWORD=replace-with-strong-redis-password

# ---- Shared application secrets ----
# Must differ from local and staging (see note above).
OMNISURG_JWT_SECRET=replace-with-strong-production-jwt-secret
OMNISURG_KEK_BASE64=replace-with-base64-encoded-32-byte-production-kek
# Shared internal API key (identity, patient, clinical, referral, billing,
# notification, scheduling read it).
OMNISURG_INTERNAL_API_KEY=replace-with-strong-internal-api-key

# ---- Afrosoft SMS (notification-service) ----
# The real Afrosoft base URL is the VAS portal host (non-secret wiring); the API
# key is a secret. Send endpoint is {base}/client/api/sendmessage.
OMNISURG_AFROSOFT_BASE_URL=https://sms.vas.co.zw
OMNISURG_AFROSOFT_API_KEY=replace-with-afrosoft-api-key

# ---- ZimRate FX upstream (currency-service) ----
# Real upstream is the ZimRate API (RBZ interbank rates, free tier). The base URL
# is non-secret wiring; the API key is a free-tier secret from the ZimRate
# dashboard. Client calls {base}/api/v1/rates?pair=USD/ZWG with Bearer auth.
OMNISURG_CURRENCY_ZIMRATE_URL=https://zimrate.statotec.com
OMNISURG_CURRENCY_ZIMRATE_API_KEY=replace-with-zimrate-api-key

# ---- Cloudflare R2 object storage (admin-bff signed-URL issuer) ----
OMNISURG_R2_ACCOUNT_ID=replace-with-r2-account-id
OMNISURG_R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
OMNISURG_R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
OMNISURG_R2_BUCKET=omnisurg-prod-blobs

# ---- Sentry DSNs (per-service project; optional, leave blank to disable) ----
OMNISURG_IDENTITY_SENTRY_DSN=
OMNISURG_TENANT_SENTRY_DSN=
OMNISURG_PATIENT_SENTRY_DSN=
OMNISURG_CLINICAL_SENTRY_DSN=
OMNISURG_REFERRAL_SENTRY_DSN=
OMNISURG_BILLING_SENTRY_DSN=
OMNISURG_PAYMENT_SENTRY_DSN=
OMNISURG_CLAIMS_SENTRY_DSN=
OMNISURG_NOTIFICATION_SENTRY_DSN=
OMNISURG_SCHEDULING_SENTRY_DSN=
OMNISURG_AUDIT_SENTRY_DSN=
OMNISURG_CURRENCY_SENTRY_DSN=
OMNISURG_ADMIN_BFF_SENTRY_DSN=
