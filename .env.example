# Postgres
POSTGRES_USER=omnisurg
POSTGRES_PASSWORD=omnisurg-local-only
POSTGRES_DB=omnisurg_meta

# Redis
REDIS_PASSWORD=omnisurg-local-only

# Traefik
TRAEFIK_DASHBOARD_PORT=8080

# Mailhog
MAILHOG_HTTP_PORT=8025
MAILHOG_SMTP_PORT=1025

# Stubs
AFROSOFT_STUB_PORT=9001
PAYNOW_STUB_PORT=9002
ZIMRATE_STUB_PORT=9003

# Afrosoft SMS (the OmniSurg SMS provider; NOT Africa's Talking).
# Local development uses the afrosoft-stub; production uses the real Afrosoft
# HTTP API. The API key is a secret: set the real value only in the gitignored
# .env (local) and in production secret storage, never in this committed example.
OMNISURG_AFROSOFT_BASE_URL=http://localhost:9001
OMNISURG_AFROSOFT_API_KEY=replace-with-afrosoft-api-key
OMNISURG_AFROSOFT_SENDER_ID=OmniSurg
